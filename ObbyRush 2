<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OBBY RUSH V2</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap');
  @import url('https://use.typekit.net/inf1yzm.css');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0a0a1a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Nunito', sans-serif;
    overflow: hidden;
  }

  #title {
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 2.8rem;
    color: #fff;
    letter-spacing: 4px;
    margin-bottom: 8px;
    text-shadow: 0 0 20px #ff6b35, 0 0 40px #ff6b35;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { text-shadow: 0 0 20px #ff6b35, 0 0 40px #ff6b35; }
    50% { text-shadow: 0 0 30px #ffcc00, 0 0 60px #ffcc00; }
  }

  #hud {
    display: flex;
    gap: 30px;
    margin-bottom: 10px;
    font-size: 1rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: 1px;
  }

  .hud-item {
    background: rgba(255,255,255,0.1);
    padding: 4px 16px;
    border-radius: 20px;
    border: 2px solid rgba(255,255,255,0.2);
  }

  #gameCanvas {
    border: 3px solid rgba(255, 107, 53, 0.6);
    border-radius: 12px;
    box-shadow: 0 0 40px rgba(255,107,53,0.3), 0 0 80px rgba(255,107,53,0.1);
    display: block;
    image-rendering: pixelated;
  }

  #controls {
    margin-top: 10px;
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
    letter-spacing: 1px;
  }

  #overlay {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    pointer-events: none;
  }

  .overlay-box {
    background: rgba(0,0,0,0.9);
    border: 3px solid #ff6b35;
    border-radius: 16px;
    padding: 28px 40px;
    text-align: center;
    color: #fff;
    pointer-events: all;
  }

  .overlay-box h2 {
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 2.2rem;
    color: #ff6b35;
    margin-bottom: 10px;
  }

  .overlay-box p { color: rgba(255,255,255,0.7); margin-bottom: 20px; font-size: 0.95rem; }

  .btn {
    background: linear-gradient(135deg, #ff6b35, #ff3b00);
    color: #fff;
    border: none;
    padding: 12px 36px;
    border-radius: 30px;
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 1.2rem;
    cursor: pointer;
    letter-spacing: 2px;
    box-shadow: 0 4px 20px rgba(255,107,53,0.5);
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .btn:hover { transform: scale(1.05); box-shadow: 0 6px 30px rgba(255,107,53,0.7); }
  .btn:active { transform: scale(0.97); }

  .btn-secondary {
    background: rgba(255,255,255,0.1);
    border: 2px solid rgba(255,255,255,0.3);
    color: #fff;
    padding: 10px 28px;
    border-radius: 30px;
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 1rem;
    cursor: pointer;
    letter-spacing: 2px;
    transition: all 0.15s;
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.2); }

  /* ── CUSTOMIZATION SCREEN ── */
  #customScreen {
    background: rgba(0,0,0,0.92);
    border: 3px solid #ff6b35;
    border-radius: 20px;
    padding: 24px 32px;
    max-width: 520px;
    width: 95vw;
    pointer-events: all;
  }

  #customScreen h2 {
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 1.8rem;
    color: #ff6b35;
    text-align: center;
    margin-bottom: 18px;
    letter-spacing: 2px;
  }

  .custom-layout {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  #previewWrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  #previewCanvas {
    background: linear-gradient(180deg, #1a1a4e 0%, #2d3a7a 100%);
    border-radius: 14px;
    border: 2px solid rgba(255,255,255,0.1);
    image-rendering: pixelated;
  }

  #previewLabel {
    font-size: 0.7rem;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
  }

  .options-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .option-group label {
    display: block;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 6px;
  }

  .swatch-row {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
  }

  .swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: transform 0.1s, border-color 0.1s;
    flex-shrink: 0;
  }

  .swatch:hover { transform: scale(1.15); }
  .swatch.selected { border-color: #fff; transform: scale(1.15); }

  .icon-row {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
  }

  .icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255,255,255,0.08);
    border: 2px solid transparent;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.1s;
  }

  .icon-btn:hover { background: rgba(255,255,255,0.15); }
  .icon-btn.selected { border-color: #ff6b35; background: rgba(255,107,53,0.2); }

  .custom-btns {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 6px;
  }

  /* ── GEAR BUTTON ── */
  #gearBtn {
    position: fixed;
    top: 14px;
    right: 18px;
    background: rgba(255,255,255,0.08);
    border: 2px solid rgba(255,255,255,0.15);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    font-size: 1.3rem;
    cursor: pointer;
    transition: all 0.2s;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: spin-idle 6s linear infinite;
  }
  #gearBtn:hover {
    background: rgba(255,107,53,0.2);
    border-color: #ff6b35;
    animation: spin-fast 0.5s linear infinite;
  }
  @keyframes spin-idle {
    0%   { transform: rotate(0deg); }
    90%  { transform: rotate(0deg); }
    100% { transform: rotate(30deg); }
  }
  @keyframes spin-fast {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ── SETTINGS MODAL ── */
  #settingsModal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    backdrop-filter: blur(4px);
  }
  #settingsModal.hidden { display: none; }

  #settingsBox {
    background: #0f1120;
    border: 3px solid #ff6b35;
    border-radius: 20px;
    padding: 28px 32px;
    width: 360px;
    max-width: 95vw;
    color: #fff;
    position: relative;
  }

  #settingsBox h2 {
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 1.8rem;
    color: #ff6b35;
    text-align: center;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .settings-close {
    position: absolute;
    top: 14px; right: 16px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.4);
    font-size: 1.4rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.15s;
  }
  .settings-close:hover { color: #fff; }

  .settings-section {
    margin-bottom: 22px;
  }

  .settings-section label {
    display: block;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 8px;
  }

  /* Code input row */
  .code-row {
    display: flex;
    gap: 8px;
  }

  #codeInput {
    flex: 1;
    background: rgba(255,255,255,0.06);
    border: 2px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    padding: 10px 14px;
    color: #fff;
    font-family: 'burbank-big-condensed', 'Fredoka One', monospace;
    font-size: 1rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    outline: none;
    transition: border-color 0.15s;
  }
  #codeInput:focus { border-color: #ff6b35; }
  #codeInput::placeholder { color: rgba(255,255,255,0.2); letter-spacing: 1px; text-transform: none; font-size: 0.85rem; }

  #redeemBtn {
    background: linear-gradient(135deg, #ff6b35, #ff3b00);
    border: none;
    border-radius: 10px;
    padding: 10px 18px;
    color: #fff;
    font-family: 'burbank-big-condensed', 'Fredoka One', cursive;
    font-size: 1rem;
    letter-spacing: 1px;
    cursor: pointer;
    transition: transform 0.1s;
    white-space: nowrap;
  }
  #redeemBtn:hover { transform: scale(1.04); }
  #redeemBtn:active { transform: scale(0.97); }

  #codeResult {
    margin-top: 10px;
    min-height: 22px;
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
    letter-spacing: 1px;
    transition: all 0.3s;
  }
  #codeResult.success { color: #4ade80; }
  #codeResult.error   { color: #f87171; }
  #codeResult.already { color: #fbbf24; }

  /* Unlocked items list */
  .unlocked-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .unlocked-tag {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 5px 12px;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .unlocked-tag .dot-secret {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #ff6b35;
    flex-shrink: 0;
  }

  .empty-unlocked {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.25);
    font-style: italic;
  }

  /* Volume toggle */
  .toggle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
  }
  .toggle {
    width: 40px; height: 22px;
    background: rgba(255,255,255,0.1);
    border-radius: 11px;
    border: 2px solid rgba(255,255,255,0.2);
    cursor: pointer;
    position: relative;
    transition: background 0.2s;
  }
  .toggle.on { background: #ff6b35; border-color: #ff6b35; }
  .toggle::after {
    content: '';
    position: absolute;
    width: 14px; height: 14px;
    background: #fff;
    border-radius: 50%;
    top: 2px; left: 2px;
    transition: transform 0.2s;
  }
  .toggle.on::after { transform: translateX(18px); }
</style>
</head>
<body>

<div id="title">🔥 OBBY RUSH V2 🔥</div>
<div id="hud">
  <div class="hud-item">❤️ LIVES: <span id="livesDisplay">3</span></div>
  <div class="hud-item">⭐ STAGE: <span id="stageDisplay">1</span></div>
  <div class="hud-item">🏆 BEST: <span id="bestDisplay">1</span></div>
</div>
<canvas id="gameCanvas" width="800" height="400"></canvas>
<div id="controls">← → MOVE &nbsp;|&nbsp; SPACE / ↑ JUMP &nbsp;|&nbsp; DOUBLE JUMP ALLOWED!</div>

<button id="gearBtn" onclick="showSettings()" title="Settings / Codes">⚙️</button>
<div id="overlay"></div>

<script>
// ═══════════════════════════════════════════
//  SECRET CODES
// ═══════════════════════════════════════════
const SECRET_CODES = {
  'DEVTOOL': {
    label: '🛠️ Dev Hat',
    reward: { hat: 'dev' },
    rarity: 'legendary',
    msg: '🛠️ DEV HAT UNLOCKED! You found a secret!'
  },
  '2026!': {
    label: '🎆 2026 Shirt',
    reward: { body: '2026' },
    rarity: 'epic',
    msg: '🎆 2026 SHIRT UNLOCKED! Happy New Year!'
  },
  'GODMODE': {
    label: '👼 Angel Wings',
    reward: { trail: 'angel' },
    rarity: 'legendary',
    msg: '👼 ANGEL WINGS UNLOCKED! You\'re untouchable!'
  },
  'LAVAKING': {
    label: '🌋 Lava Crown',
    reward: { hat: 'lava' },
    rarity: 'epic',
    msg: '🌋 LAVA CROWN UNLOCKED! Bow to the king!'
  },
  'NEON99': {
    label: '💜 Neon Body',
    reward: { body: 'neon' },
    rarity: 'rare',
    msg: '💜 NEON BODY UNLOCKED! Glow up!'
  },
};

let unlockedCodes = JSON.parse(localStorage.getItem('obbyUnlocked') || '[]');

function redeemCode(raw) {
  const code = raw.trim().toUpperCase().replace('!','!'); // keep ! for 2026!
  const entry = SECRET_CODES[raw.trim().toUpperCase()] || SECRET_CODES[raw.trim()];
  if (!entry) return { status: 'error', msg: '❌ Invalid code. Try again!' };
  if (unlockedCodes.includes(raw.trim().toUpperCase()) || unlockedCodes.includes(raw.trim())) {
    return { status: 'already', msg: '⚠️ Already redeemed!' };
  }
  // Apply reward
  const key = Object.keys(entry.reward)[0];
  const val = entry.reward[key];
  if (key === 'hat') secretItems.hats.push(val);
  if (key === 'body') secretItems.bodies.push(val);
  if (key === 'trail') secretItems.trails.push(val);
  unlockedCodes.push(raw.trim().toUpperCase());
  unlockedCodes.push(raw.trim()); // store both variants
  localStorage.setItem('obbyUnlocked', JSON.stringify([...new Set(unlockedCodes)]));
  return { status: 'success', msg: entry.msg };
}

// Secret items unlocked via codes (persisted)
const secretItems = { hats: [], bodies: [], trails: [] };
// Restore from saved codes
unlockedCodes.forEach(c => {
  const entry = SECRET_CODES[c];
  if (!entry) return;
  const key = Object.keys(entry.reward)[0];
  const val = entry.reward[key];
  if (key === 'hat' && !secretItems.hats.includes(val)) secretItems.hats.push(val);
  if (key === 'body' && !secretItems.bodies.includes(val)) secretItems.bodies.push(val);
  if (key === 'trail' && !secretItems.trails.includes(val)) secretItems.trails.push(val);
});


const SKIN_COLORS = ['#ffcc80','#f5c5a3','#d4956a','#a0624a','#6b3a2a','#ffe0b2'];
const BODY_COLORS = ['#4fc3f7','#ef5350','#66bb6a','#ab47bc','#ffa726','#ec407a','#26c6da','#ffffff'];
const EYE_STYLES  = ['normal','sleepy','wide','cross','star','cool'];
const HATS        = ['none','cap','crown','party','wizard','halo'];
const TRAILS      = ['none','fire','star','rainbow','ice'];

let cosmetics = {
  skin: SKIN_COLORS[0],
  body: BODY_COLORS[0],
  eyes: 'normal',
  hat:  'none',
  trail: 'none',
};

// preview canvas
const pCv  = document.createElement('canvas');
pCv.width  = 80; pCv.height = 110;
pCv.id     = 'previewCanvas';
const pCtx = pCv.getContext('2d');

let previewAnim = 0;
function drawPreviewChar() {
  pCtx.clearRect(0, 0, 80, 110);

  // bg platform
  pCtx.fillStyle = '#4a9e3f';
  pCtx.fillRect(0, 90, 80, 20);
  pCtx.fillStyle = '#6fcf57';
  pCtx.fillRect(0, 90, 80, 7);

  drawCharacter(pCtx, 26, 44, cosmetics, previewAnim, true);
}

// ═══════════════════════════════════════════
//  SHARED CHARACTER DRAW FUNCTION
// ═══════════════════════════════════════════
function drawCharacter(ctx, px, py, cos, frame, preview) {
  const w = 28, h = 36;

  // Trail effect (game only)
  if (!preview && cos.trail !== 'none') {
    drawTrail(ctx, px, py, w, h, cos.trail, frame);
  }

  // Shadow
  ctx.fillStyle = 'rgba(0,0,0,0.25)';
  ctx.fillRect(px + 2, py + h + 2, w - 4, 5);

  // Body
  const bodyGrad = ctx.createLinearGradient(px, py + 12, px, py + h);
  const bc = cos.body;
  bodyGrad.addColorStop(0, bc);
  bodyGrad.addColorStop(1, shadeColor(bc, -40));
  ctx.fillStyle = bodyGrad;
  ctx.beginPath();
  if (ctx.roundRect) ctx.roundRect(px, py + 12, w, h - 12, 4);
  else ctx.rect(px, py + 12, w, h - 12);
  ctx.fill();

  // Outfit stripe
  ctx.fillStyle = 'rgba(255,255,255,0.25)';
  ctx.fillRect(px + 4, py + 16, w - 8, 4);

  // Special body overlays
  if (cos.body === '2026') {
    // 2026 shirt - golden with text
    const sg = ctx.createLinearGradient(px, py+12, px, py+h);
    sg.addColorStop(0, '#fbbf24'); sg.addColorStop(1, '#b45309');
    ctx.fillStyle = sg;
    if (ctx.roundRect) ctx.roundRect(px, py + 12, w, h - 12, 4);
    else ctx.rect(px, py + 12, w, h - 12);
    ctx.fill();
    ctx.fillStyle = '#1a1a2e';
    ctx.font = 'bold 6px monospace';
    ctx.fillText('2026', px + 3, py + 26);
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.fillRect(px + 4, py + 16, w - 8, 3);
  } else if (cos.body === 'neon') {
    // neon purple glowing shirt
    const ng = ctx.createLinearGradient(px, py+12, px, py+h);
    ng.addColorStop(0, '#a855f7'); ng.addColorStop(1, '#6d28d9');
    ctx.fillStyle = ng;
    if (ctx.roundRect) ctx.roundRect(px, py + 12, w, h - 12, 4);
    else ctx.rect(px, py + 12, w, h - 12);
    ctx.fill();
    ctx.shadowBlur = 10; ctx.shadowColor = '#a855f7';
    ctx.strokeStyle = '#d8b4fe';
    ctx.lineWidth = 1;
    ctx.strokeRect(px + 1, py + 13, w - 2, h - 14);
    ctx.shadowBlur = 0; ctx.lineWidth = 1;
  }

  // Head
  ctx.fillStyle = cos.skin;
  ctx.beginPath();
  ctx.ellipse(px + w/2, py + 9, 12, 11, 0, 0, Math.PI * 2);
  ctx.fill();

  // Eyes
  drawEyes(ctx, px, py, cos.eyes, frame);

  // Hat
  drawHat(ctx, px, py, w, cos.hat, frame);

  // Legs (animated)
  ctx.fillStyle = shadeColor(cos.body, -60);
  const legSwing = frame ? Math.sin(frame * 0.3) * 5 : 0;
  ctx.fillRect(px + 4, py + h - 8, 8, 10 + legSwing);
  ctx.fillRect(px + w - 12, py + h - 8, 8, 10 - legSwing);

  // Shoes
  ctx.fillStyle = '#1a1a2e';
  ctx.fillRect(px + 3, py + h + 1 + legSwing, 10, 4);
  ctx.fillRect(px + w - 13, py + h + 1 - legSwing, 10, 4);
}

function drawEyes(ctx, px, py, style, frame) {
  ctx.fillStyle = '#1a1a2e';
  switch(style) {
    case 'normal':
      ctx.fillRect(px + 6, py + 5, 4, 5);
      ctx.fillRect(px + 16, py + 5, 4, 5);
      ctx.fillStyle = '#fff';
      ctx.fillRect(px + 7, py + 5, 2, 2);
      ctx.fillRect(px + 17, py + 5, 2, 2);
      break;
    case 'sleepy':
      ctx.fillRect(px + 5, py + 7, 6, 2);
      ctx.fillRect(px + 15, py + 7, 6, 2);
      break;
    case 'wide':
      ctx.beginPath();
      ctx.arc(px + 9, py + 7, 4, 0, Math.PI*2);
      ctx.arc(px + 20, py + 7, 4, 0, Math.PI*2);
      ctx.fill();
      ctx.fillStyle = '#fff';
      ctx.fillRect(px + 8, py + 5, 2, 2);
      ctx.fillRect(px + 19, py + 5, 2, 2);
      break;
    case 'cross':
      ctx.strokeStyle = '#1a1a2e';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(px+5,py+4); ctx.lineTo(px+10,py+9);
      ctx.moveTo(px+10,py+4); ctx.lineTo(px+5,py+9);
      ctx.moveTo(px+15,py+4); ctx.lineTo(px+20,py+9);
      ctx.moveTo(px+20,py+4); ctx.lineTo(px+15,py+9);
      ctx.stroke();
      ctx.lineWidth = 1;
      break;
    case 'star':
      ctx.fillStyle = '#fbbf24';
      ctx.font = '9px serif';
      ctx.fillText('★', px + 4, py + 10);
      ctx.fillText('★', px + 15, py + 10);
      break;
    case 'cool':
      ctx.fillStyle = '#1a1a2e';
      ctx.fillRect(px + 4, py + 5, 8, 4);
      ctx.fillRect(px + 14, py + 5, 8, 4);
      ctx.fillStyle = 'rgba(0,0,0,0.5)';
      ctx.fillRect(px + 4, py + 5, 8, 4);
      ctx.fillRect(px + 14, py + 5, 8, 4);
      break;
  }
}

function drawHat(ctx, px, py, w, hat, frame) {
  const cx = px + w/2;
  switch(hat) {
    case 'none': break;
    case 'cap':
      ctx.fillStyle = '#e53935';
      ctx.fillRect(px - 2, py - 6, w + 4, 5);
      ctx.fillRect(px + 3, py - 14, w - 4, 10);
      ctx.fillStyle = '#fff';
      ctx.fillRect(px + 8, py - 13, 4, 3);
      break;
    case 'crown':
      ctx.fillStyle = '#fbbf24';
      ctx.beginPath();
      ctx.moveTo(px + 2, py - 3);
      ctx.lineTo(px + 2, py - 14);
      ctx.lineTo(cx - 4, py - 8);
      ctx.lineTo(cx, py - 16);
      ctx.lineTo(cx + 4, py - 8);
      ctx.lineTo(px + w - 2, py - 14);
      ctx.lineTo(px + w - 2, py - 3);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = '#ef4444';
      ctx.beginPath(); ctx.arc(px+4, py-14, 3, 0, Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(cx, py-16, 3, 0, Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(px+w-4, py-14, 3, 0, Math.PI*2); ctx.fill();
      break;
    case 'party':
      ctx.fillStyle = '#a855f7';
      ctx.beginPath();
      ctx.moveTo(px+4, py-2);
      ctx.lineTo(cx, py-20);
      ctx.lineTo(px+w-4, py-2);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = '#fbbf24';
      ctx.beginPath(); ctx.arc(cx, py-20, 3, 0, Math.PI*2); ctx.fill();
      // polka dots
      ['#f87171','#4ade80','#60a5fa'].forEach((c,i) => {
        ctx.fillStyle = c;
        ctx.beginPath(); ctx.arc(cx - 4 + i*4, py - 8 - i*3, 2, 0, Math.PI*2); ctx.fill();
      });
      break;
    case 'wizard':
      ctx.fillStyle = '#4338ca';
      ctx.beginPath();
      ctx.moveTo(px+2, py-2);
      ctx.lineTo(cx, py-28);
      ctx.lineTo(px+w-2, py-2);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = '#6366f1';
      ctx.fillRect(px-4, py-4, w+8, 5);
      ctx.fillStyle = '#fbbf24';
      const wobble = Math.sin((frame||0)*0.08)*2;
      ctx.beginPath(); ctx.arc(cx+wobble, py-28, 4, 0, Math.PI*2); ctx.fill();
      break;
    case 'halo':
      ctx.strokeStyle = '#fde68a';
      ctx.lineWidth = 3;
      ctx.shadowBlur = 10;
      ctx.shadowColor = '#fbbf24';
      ctx.beginPath();
      ctx.ellipse(cx, py - 14 + Math.sin((frame||0)*0.05)*2, 12, 4, 0, 0, Math.PI*2);
      ctx.stroke();
      ctx.shadowBlur = 0;
      ctx.lineWidth = 1;
      break;
    case 'dev':
      // flat dev cap (dark with DEV text)
      ctx.fillStyle = '#1e1e2e';
      ctx.fillRect(px - 2, py - 6, w + 4, 5);
      ctx.fillRect(px + 3, py - 16, w - 4, 11);
      ctx.fillStyle = '#ff6b35';
      ctx.fillRect(px + 3, py - 16, w - 4, 4);
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 5px monospace';
      ctx.fillText('DEV', px + 6, py - 8);
      ctx.fillStyle = '#ff6b35';
      ctx.fillRect(px - 2, py - 7, w + 4, 2);
      break;
    case 'lava':
      // glowing lava crown
      ctx.shadowBlur = 14; ctx.shadowColor = '#ff4500';
      ctx.fillStyle = '#cc2200';
      ctx.beginPath();
      ctx.moveTo(px + 2, py - 3);
      ctx.lineTo(px + 2, py - 13);
      ctx.lineTo(cx - 5, py - 7);
      ctx.lineTo(cx, py - 17);
      ctx.lineTo(cx + 5, py - 7);
      ctx.lineTo(px + w - 2, py - 13);
      ctx.lineTo(px + w - 2, py - 3);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = '#ff6b35';
      ctx.beginPath(); ctx.arc(px+4, py-13, 3, 0, Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(cx, py-17, 3, 0, Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(px+w-4, py-13, 3, 0, Math.PI*2); ctx.fill();
      ctx.shadowBlur = 0;
      break;
  }
}

function drawTrail(ctx, px, py, w, h, trail, frame) {
  const particles = 6;
  for (let i = 0; i < particles; i++) {
    const age = (frame - i * 3);
    const alpha = Math.max(0, 0.4 - i * 0.06);
    const ox = -i * 5;
    const oy = Math.sin(age * 0.3 + i) * 3;
    ctx.globalAlpha = alpha;
    switch(trail) {
      case 'fire':
        ctx.fillStyle = i % 2 === 0 ? '#ff6b35' : '#fbbf24';
        ctx.beginPath();
        ctx.ellipse(px + w/2 + ox, py + h/2 + oy, 6 - i, 8 - i, 0, 0, Math.PI*2);
        ctx.fill();
        break;
      case 'star':
        ctx.fillStyle = '#fbbf24';
        ctx.font = `${10 - i}px serif`;
        ctx.fillText('★', px + ox, py + h/2 + oy);
        break;
      case 'rainbow':
        const colors = ['#f87171','#fbbf24','#4ade80','#60a5fa','#a78bfa','#f472b6'];
        ctx.fillStyle = colors[i % colors.length];
        ctx.beginPath();
        ctx.arc(px + w/2 + ox, py + h/2 + oy, 5 - i*0.5, 0, Math.PI*2);
        ctx.fill();
        break;
      case 'ice':
        ctx.fillStyle = '#bfdbfe';
        ctx.beginPath();
        ctx.arc(px + w/2 + ox, py + h/2 + oy, 4 - i*0.4, 0, Math.PI*2);
        ctx.fill();
        break;
      case 'angel':
        ctx.fillStyle = '#fde68a';
        ctx.shadowBlur = 8; ctx.shadowColor = '#fff';
        ctx.beginPath();
        ctx.arc(px + w/2 + ox, py + oy - 2, 3 - i*0.3, 0, Math.PI*2);
        ctx.fill();
        ctx.shadowBlur = 0;
        break;
    }
    ctx.globalAlpha = 1;
  }
}

function shadeColor(hex, amt) {
  let r = parseInt(hex.slice(1,3),16);
  let g = parseInt(hex.slice(3,5),16);
  let b = parseInt(hex.slice(5,7),16);
  r = Math.max(0,Math.min(255,r+amt));
  g = Math.max(0,Math.min(255,g+amt));
  b = Math.max(0,Math.min(255,b+amt));
  return `rgb(${r},${g},${b})`;
}


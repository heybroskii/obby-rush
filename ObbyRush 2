// ═══════════════════════════════════════════
//  GAME ENGINE
// ═══════════════════════════════════════════
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const W = canvas.width, H = canvas.height;
const GRAVITY = 0.55;
const PLAYER_SPEED = 4.5;
const JUMP_FORCE = -13;
const GROUND_Y = H - 50;

let gameState = 'start';
let lives = 3, stage = 1;
let bestStage = parseInt(localStorage.getItem('obbyBest') || '1');
let keys = {};
let cameraX = 0;
let animFrame = 0;
let dyingLock = false;
let rafId = null;

let player = {};
function resetPlayer() {
  player = {
    x: 60, y: GROUND_Y - 36,
    vx: 0, vy: 0,
    w: 28, h: 36,
    onGround: false,
    jumpsLeft: 2,
    dead: false,
  };
  cameraX = 0;
  dyingLock = false;
}

// Difficulty helpers
function diffLerp(stage, startVal, endVal, cap) {
  return Math.min(startVal + (endVal - startVal) * ((stage - 1) / (cap - 1)), endVal);
}

function buildLevel(stageNum) {
  const platforms = [], lava = [], movingPlatforms = [], spikes = [];

  // ── Difficulty knobs ──────────────────────────────────────────
  const gapBase       = 75 + Math.min(stageNum * 8, 70);   // lava gap width
  const mpSpeed       = diffLerp(stageNum, 1.4, 4.2, 12);  // moving platform speed
  const mpWidth       = Math.max(80 - stageNum * 4, 44);   // platform narrows
  const spikeChance   = Math.min(0.12 * (stageNum - 1), 0.7); // probability per platform tile
  const sections      = 4 + Math.min(stageNum * 2, 14);    // more sections
  const platformW     = () => Math.max(60, (120 - stageNum * 4) + (Math.random() * 50 | 0));

  // Narrow sky colour gets more hellish each tier
  // (just data — drawBackground reads stage directly)

  // Always start with safe ground
  platforms.push({ x: 0, y: GROUND_Y, w: 260, h: 50, color: '#4a9e3f' });
  let x = 280;

  for (let i = 0; i < sections; i++) {
    // From stage 5+ introduce a 4th section type: spike gauntlet
    const typeCount = stageNum >= 5 ? 4 : 3;
    const type = i % typeCount;

    if (type === 0) {
      // ── Lava gap ──────────────────────────────────────────────
      const gapW = gapBase + (Math.random() * 20 | 0);
      lava.push({ x, y: GROUND_Y + 4, w: gapW, h: 46 });
      x += gapW;
      const pw = platformW();
      const landPlat = { x, y: GROUND_Y, w: pw, h: 50, color: '#4a9e3f' };
      platforms.push(landPlat);
      // maybe spike on landing platform (not first tile, give player room)
      if (stageNum >= 2) addSpikesToPlatform(spikes, landPlat, spikeChance, 16);
      x += pw + 20;

    } else if (type === 1) {
      // ── Elevated platform over lava ───────────────────────────
      const pw = 70 + (Math.random() * 50 | 0);
      const elevY = GROUND_Y - 65 - (Math.random() * 45 | 0);
      const elevPlat = { x, y: elevY, w: pw, h: 18, color: '#6ab04c' };
      platforms.push(elevPlat);
      lava.push({ x, y: GROUND_Y + 4, w: pw + 60, h: 46 });
      if (stageNum >= 3) addSpikesToPlatform(spikes, elevPlat, spikeChance * 0.8, 0);
      x += pw + 60;
      const landPlat = { x, y: GROUND_Y, w: 100, h: 50, color: '#4a9e3f' };
      platforms.push(landPlat);
      if (stageNum >= 4) addSpikesToPlatform(spikes, landPlat, spikeChance * 0.5, 12);
      x += 120;

    } else if (type === 2) {
      // ── Moving platform over lava ─────────────────────────────
      const gapW = 90 + stageNum * 12;
      lava.push({ x, y: GROUND_Y + 4, w: gapW + 40, h: 46 });
      movingPlatforms.push({
        x, y: GROUND_Y - 50 - (stageNum > 4 ? Math.random() * 30 | 0 : 0),
        w: mpWidth, h: 16,
        startX: x, endX: x + gapW,
        speed: mpSpeed + Math.random() * 0.4,
        dir: 1, color: '#f0a500'
      });
      // Stage 7+: add a second faster moving platform on same gap
      if (stageNum >= 7) {
        movingPlatforms.push({
          x: x + gapW * 0.4, y: GROUND_Y - 80,
          w: mpWidth - 12, h: 16,
          startX: x, endX: x + gapW,
          speed: mpSpeed * 1.4,
          dir: -1, color: '#ff8c00'
        });
      }
      x += gapW + 60;
      const landPlat = { x, y: GROUND_Y, w: 120, h: 50, color: '#4a9e3f' };
      platforms.push(landPlat);
      if (stageNum >= 5) addSpikesToPlatform(spikes, landPlat, spikeChance * 0.6, 14);
      x += 140;

    } else {
      // ── type 3: Spike gauntlet (stage 5+) ────────────────────
      const runW = 120 + (Math.random() * 60 | 0);
      const gauntPlat = { x, y: GROUND_Y, w: runW, h: 50, color: '#3a7a30' };
      platforms.push(gauntPlat);
      // Dense spikes — every 16px
      for (let sx = x + 8; sx < x + runW - 16; sx += 16) {
        spikes.push({ x: sx, y: GROUND_Y - 14, w: 12, h: 14 });
      }
      x += runW + 20;
      // Short safe landing
      platforms.push({ x, y: GROUND_Y, w: 50, h: 50, color: '#4a9e3f' });
      x += 70;
    }
  }

  // Final flag platform — always spike-free
  platforms.push({ x, y: GROUND_Y, w: 130, h: 50, color: '#4a9e3f' });
  const flagX = x + 30;
  return { platforms, lava, movingPlatforms, spikes, flagX };
}

// Helper: scatter spikes across a platform top, leaving `safeLeft` px gap at start
function addSpikesToPlatform(spikes, plat, chance, safeLeft) {
  const spacing = 16;
  for (let sx = plat.x + safeLeft; sx < plat.x + plat.w - 12; sx += spacing) {
    if (Math.random() < chance) {
      spikes.push({ x: sx, y: plat.y - 14, w: 12, h: 14 });
    }
  }
}

let level = {};

function startGame() {
  lives = 3;
  stage = 1;
  level = buildLevel(stage);
  resetPlayer();
  gameState = 'playing';
  document.getElementById('overlay').innerHTML = '';
  updateHUD();
  stopLoop();
  rafId = requestAnimationFrame(loop);
}

function nextStage() {
  stage++;
  if (stage > bestStage) { bestStage = stage; localStorage.setItem('obbyBest', bestStage); }
  level = buildLevel(stage);
  resetPlayer();
  gameState = 'playing';
  document.getElementById('overlay').innerHTML = '';
  updateHUD();
  stopLoop();
  rafId = requestAnimationFrame(loop);
}

function loseLife() {
  if (dyingLock) return;
  dyingLock = true;
  lives--;
  updateHUD();
  if (lives <= 0) {
    gameState = 'gameover';
    showOverlay('GAME OVER', `You reached Stage ${stage}!`, '🎨 CUSTOMIZE', showCustomScreen, '🔁 RETRY', startGame);
  } else {
    gameState = 'dead';
    setTimeout(() => { resetPlayer(); gameState = 'playing'; }, 1000);
  }
}

function showOverlay(title, msg, btn1Text, fn1, btn2Text, fn2) {
  const box = document.createElement('div');
  box.className = 'overlay-box';
  const h = document.createElement('h2'); h.textContent = title;
  const p = document.createElement('p'); p.textContent = msg;
  box.append(h, p);
  if (fn2) {
    const row = document.createElement('div');
    row.style.cssText = 'display:flex;gap:10px;justify-content:center;flex-wrap:wrap';
    const b1 = document.createElement('button');
    b1.className = 'btn-secondary'; b1.textContent = btn1Text; b1.onclick = fn1;
    const b2 = document.createElement('button');
    b2.className = 'btn'; b2.textContent = btn2Text; b2.onclick = fn2;
    row.append(b1, b2);
    box.appendChild(row);
  } else {
    const b = document.createElement('button');
    b.className = 'btn'; b.textContent = btn1Text; b.onclick = fn1;
    box.appendChild(b);
  }
  const ov = document.getElementById('overlay');
  ov.innerHTML = '';
  ov.appendChild(box);
}

function updateHUD() {
  document.getElementById('livesDisplay').textContent = lives;
  document.getElementById('stageDisplay').textContent = stage;
  document.getElementById('bestDisplay').textContent = bestStage;
}

function stopLoop() {
  if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
}

// Input
document.addEventListener('keydown', e => {
  keys[e.code] = true;
  if ((e.code === 'Space' || e.code === 'ArrowUp') && gameState === 'playing') {
    e.preventDefault();
    if (player.jumpsLeft > 0) {
      player.vy = JUMP_FORCE;
      player.jumpsLeft--;
      player.onGround = false;
    }
  }
});
document.addEventListener('keyup', e => keys[e.code] = false);

function update() {
  if (gameState !== 'playing') return;
  animFrame++;

  if (keys['ArrowLeft'] || keys['KeyA']) player.vx = -PLAYER_SPEED;
  else if (keys['ArrowRight'] || keys['KeyD']) player.vx = PLAYER_SPEED;
  else player.vx *= 0.8;

  player.vy += GRAVITY;
  player.x += player.vx;
  player.y += player.vy;

  const targetCam = player.x - W * 0.35;
  cameraX += (targetCam - cameraX) * 0.12;
  if (cameraX < 0) cameraX = 0;

  // Platform movement
  for (const mp of level.movingPlatforms) {
    mp.x += mp.speed * mp.dir;
    if (mp.x > mp.endX) { mp.x = mp.endX; mp.dir = -1; }
    if (mp.x < mp.startX) { mp.x = mp.startX; mp.dir = 1; }
  }

  // Collision
  player.onGround = false;
  const allPlatforms = [...level.platforms, ...level.movingPlatforms];
  for (const p of allPlatforms) {
    if (
      player.x + player.w > p.x && player.x < p.x + p.w &&
      player.y + player.h > p.y && player.y + player.h < p.y + p.h + 14 && player.vy >= 0
    ) {
      player.y = p.y - player.h;
      player.vy = 0;
      player.onGround = true;
      player.jumpsLeft = 2;
      if (p.speed !== undefined) player.x += p.speed * p.dir;
    }
  }

  // Lava
  for (const lv of level.lava) {
    if (player.x + player.w > lv.x + 4 && player.x < lv.x + lv.w - 4 && player.y + player.h > lv.y) {
      loseLife(); return;
    }
  }

  // Spikes
  for (const sp of level.spikes) {
    if (
      player.x + player.w - 3 > sp.x + 2 &&
      player.x + 3        < sp.x + sp.w - 2 &&
      player.y + player.h > sp.y + 4 &&
      player.y            < sp.y + sp.h
    ) { loseLife(); return; }
  }

  if (player.y > H + 100) { loseLife(); return; }

  // Flag
  if (player.x + player.w > level.flagX && player.x < level.flagX + 30) {
    gameState = 'win';
    if (stage > bestStage) { bestStage = stage; localStorage.setItem('obbyBest', bestStage); }
    updateHUD();
    showOverlay('STAGE CLEAR! 🎉', `Amazing! Onto Stage ${stage + 1}...`, '▶ NEXT STAGE', nextStage);
  }
}

function drawBackground() {
  // Sky shifts from deep blue → purple → blood red as stage increases
  const t = Math.min((stage - 1) / 9, 1);
  const sky = ctx.createLinearGradient(0, 0, 0, H);
  const topA = lerpColor('#1a1a4e', '#2a0a1e', t);
  const midA = lerpColor('#2d3a7a', '#5a1a3a', t);
  const botA = lerpColor('#1a2040', '#1a0a10', t);
  sky.addColorStop(0,   topA);
  sky.addColorStop(0.6, midA);
  sky.addColorStop(1,   botA);
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, W, H);

  // Stars — more at high stages
  const starCount = 40 + Math.min(stage * 8, 80);
  ctx.fillStyle = stage >= 6 ? 'rgba(255,160,160,0.7)' : 'rgba(255,255,255,0.6)';
  for (let i = 0; i < starCount; i++) {
    const sx = (i * 137 + animFrame * 0.05) % W;
    const sy = (i * 73) % (H * 0.6);
    ctx.fillRect(sx, sy, (i%3===0)?2:1, (i%3===0)?2:1);
  }

  // Clouds
  ctx.fillStyle = stage >= 5 ? 'rgba(180,80,80,0.07)' : 'rgba(255,255,255,0.08)';
  for (let i = 0; i < 4; i++) {
    const cx = ((i * 250 - cameraX * 0.2) % (W + 200) + W + 200) % (W + 200) - 100;
    const cy = 50 + i * 35;
    ctx.beginPath(); ctx.ellipse(cx, cy, 70, 25, 0, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(cx + 50, cy - 10, 50, 20, 0, 0, Math.PI * 2); ctx.fill();
  }
}

function lerpColor(hex1, hex2, t) {
  const r1=parseInt(hex1.slice(1,3),16), g1=parseInt(hex1.slice(3,5),16), b1=parseInt(hex1.slice(5,7),16);
  const r2=parseInt(hex2.slice(1,3),16), g2=parseInt(hex2.slice(3,5),16), b2=parseInt(hex2.slice(5,7),16);
  const r=Math.round(r1+(r2-r1)*t), g=Math.round(g1+(g2-g1)*t), b=Math.round(b1+(b2-b1)*t);
  return `rgb(${r},${g},${b})`;
}

function drawLava(lv) {
  const lx = lv.x - cameraX;
  const grad = ctx.createLinearGradient(lx, lv.y, lx, lv.y + lv.h);
  grad.addColorStop(0, '#ff4500'); grad.addColorStop(0.4, '#cc2200'); grad.addColorStop(1, '#880000');
  ctx.fillStyle = grad;
  ctx.fillRect(lx, lv.y, lv.w, lv.h);
  ctx.fillStyle = '#ff6a00';
  for (let i = 0; i < Math.floor(lv.w / 20); i++) {
    const bx = lx + 10 + i * 20;
    const by = lv.y + 6 + Math.sin(animFrame * 0.08 + i) * 4;
    ctx.beginPath(); ctx.ellipse(bx, by, 8, 5, 0, 0, Math.PI * 2); ctx.fill();
  }
  ctx.shadowBlur = 20; ctx.shadowColor = '#ff4500';
  ctx.fillStyle = 'rgba(255,69,0,0.3)';
  ctx.fillRect(lx, lv.y - 8, lv.w, 8);
  ctx.shadowBlur = 0;
}

function drawSpikes(sp) {
  const sx = Math.round(sp.x - cameraX);
  if (sx + sp.w < -10 || sx > W + 10) return;

  // Metallic spike body
  const grad = ctx.createLinearGradient(sx, sp.y, sx + sp.w, sp.y + sp.h);
  grad.addColorStop(0, '#b0b8c8');
  grad.addColorStop(0.45, '#e8edf5');
  grad.addColorStop(1, '#606878');
  ctx.fillStyle = grad;

  // Draw triangle spike
  ctx.beginPath();
  ctx.moveTo(sx,           sp.y + sp.h);   // bottom-left
  ctx.lineTo(sx + sp.w/2,  sp.y);           // tip
  ctx.lineTo(sx + sp.w,    sp.y + sp.h);   // bottom-right
  ctx.closePath();
  ctx.fill();

  // Shine line
  ctx.strokeStyle = 'rgba(255,255,255,0.6)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(sx + sp.w * 0.35, sp.y + sp.h * 0.85);
  ctx.lineTo(sx + sp.w * 0.5,  sp.y + sp.h * 0.1);
  ctx.stroke();
  ctx.lineWidth = 1;

  // Red glow at base (danger indicator)
  ctx.fillStyle = 'rgba(220,30,30,0.25)';
  ctx.fillRect(sx, sp.y + sp.h - 4, sp.w, 4);
}

function drawPlatform(p) {
  const px = Math.round(p.x - cameraX);
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.fillRect(px + 4, p.y + 4, p.w, p.h);
  ctx.fillStyle = p.color || '#4a9e3f';
  ctx.fillRect(px, p.y, p.w, p.h);
  if (!p.speed) {
    ctx.fillStyle = '#6fcf57';
    ctx.fillRect(px, p.y, p.w, 8);
    ctx.fillStyle = '#5bb548';
    for (let i = 4; i < p.w - 4; i += 12) ctx.fillRect(px + i, p.y - 4, 3, 6);
    ctx.fillStyle = '#3a7e30';
    for (let i = 0; i < 3; i++) ctx.fillRect(px + 10 + i * (p.w/3), p.y + 14, 12, 4);
  } else {
    const grd = ctx.createLinearGradient(px, p.y, px, p.y + p.h);
    grd.addColorStop(0, '#ffcc44'); grd.addColorStop(1, '#e08800');
    ctx.fillStyle = grd;
    ctx.fillRect(px, p.y, p.w, p.h);
    ctx.fillStyle = '#fff176';
    ctx.fillRect(px + 4, p.y + 3, p.w - 8, 4);
    ctx.shadowBlur = 12; ctx.shadowColor = '#ffaa00';
    ctx.fillStyle = 'rgba(255,200,0,0.2)';
    ctx.fillRect(px, p.y, p.w, p.h);
    ctx.shadowBlur = 0;
  }
}

function drawFlag() {
  const fx = level.flagX - cameraX;
  if (fx < -10 || fx > W + 10) return;
  ctx.fillStyle = '#ccc';
  ctx.fillRect(fx, GROUND_Y - 100, 4, 100);
  ctx.fillStyle = '#ff3b00';
  for (let i = 0; i < 3; i++) {
    const wave = Math.sin(animFrame * 0.1 + i * 0.5) * 4;
    ctx.fillRect(fx + 4 + i * 10, GROUND_Y - 95 + wave, 10, 22);
  }
  ctx.shadowBlur = 15; ctx.shadowColor = '#ffcc00';
  ctx.fillStyle = '#ffee00';
  ctx.beginPath(); ctx.arc(fx + 2, GROUND_Y - 102, 6, 0, Math.PI * 2); ctx.fill();
  ctx.shadowBlur = 0;
}

function drawPlayer() {
  const px = Math.round(player.x - cameraX);
  const py = Math.round(player.y);
  if (gameState === 'dead') {
    ctx.globalAlpha = Math.sin(animFrame * 0.3) > 0 ? 0.5 : 0;
  }
  drawCharacter(ctx, px, py, cosmetics, player.onGround ? animFrame : 0, false);
  ctx.globalAlpha = 1;
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  drawBackground();
  for (const lv of level.lava) {
    if (lv.x - cameraX < W + 100 && lv.x + lv.w - cameraX > -100) drawLava(lv);
  }
  for (const p of level.platforms) {
    if (p.x - cameraX < W + 100 && p.x + p.w - cameraX > -100) drawPlatform(p);
  }
  for (const mp of level.movingPlatforms) drawPlatform(mp);
  // Draw spikes on top of platforms
  for (const sp of level.spikes) drawSpikes(sp);
  drawFlag();
  drawPlayer();
  if (player.x < 100 && gameState === 'playing') {
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = 'bold 16px Nunito';
    ctx.fillText('→ GO RIGHT!', 20, 30);
  }
  // Stage label + difficulty tier
  const tierLabel = stage <= 2 ? '🟢 EASY' : stage <= 4 ? '🟡 MEDIUM' : stage <= 6 ? '🟠 HARD' : stage <= 8 ? '🔴 BRUTAL' : '💀 INSANE';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.font = 'bold 13px Nunito';
  ctx.textAlign = 'right';
  ctx.fillText(`STAGE ${stage}  ${tierLabel}`, W - 12, 24);
  ctx.textAlign = 'left';
}

function loop() {
  update();
  draw();
  rafId = requestAnimationFrame(loop);
}

// ═══════════════════════════════════════════
//  SETTINGS MODAL
// ═══════════════════════════════════════════
function showSettings() {
  // Remove any existing modal
  const existing = document.getElementById('settingsModal');
  if (existing) { existing.remove(); return; }

  const modal = document.createElement('div');
  modal.id = 'settingsModal';
  modal.onclick = e => { if (e.target === modal) modal.remove(); };

  const box = document.createElement('div');
  box.id = 'settingsBox';

  // Close button
  const closeBtn = document.createElement('button');
  closeBtn.className = 'settings-close';
  closeBtn.textContent = '✕';
  closeBtn.onclick = () => modal.remove();
  box.appendChild(closeBtn);

  // Title
  const h2 = document.createElement('h2');
  h2.textContent = '⚙️ SETTINGS';
  box.appendChild(h2);

  // ── SECRET CODE section ──
  const codeSection = document.createElement('div');
  codeSection.className = 'settings-section';
  const codeLbl = document.createElement('label');
  codeLbl.textContent = '🔑 Enter Secret Code';
  codeSection.appendChild(codeLbl);

  const codeRow = document.createElement('div');
  codeRow.className = 'code-row';

  const input = document.createElement('input');
  input.id = 'codeInput';
  input.type = 'text';
  input.placeholder = 'Type code here...';
  input.maxLength = 20;
  input.autocomplete = 'off';
  input.spellcheck = false;

  const redeemBtn = document.createElement('button');
  redeemBtn.id = 'redeemBtn';
  redeemBtn.textContent = 'REDEEM';

  const result = document.createElement('div');
  result.id = 'codeResult';

  redeemBtn.onclick = () => {
    const res = redeemCode(input.value);
    result.textContent = res.msg;
    result.className = res.status;
    input.value = '';
    if (res.status === 'success') {
      renderUnlocked();
      // Sparkle animation on box
      box.style.borderColor = '#4ade80';
      setTimeout(() => { box.style.borderColor = '#ff6b35'; }, 1200);
    }
  };

  input.addEventListener('keydown', e => { if (e.key === 'Enter') redeemBtn.click(); });

  codeRow.append(input, redeemBtn);
  codeSection.append(codeRow, result);
  box.appendChild(codeSection);

  // ── UNLOCKED items section ──
  const unlockedSection = document.createElement('div');
  unlockedSection.className = 'settings-section';
  const unlockedLbl = document.createElement('label');
  unlockedLbl.textContent = '🎁 Unlocked Items';
  unlockedSection.appendChild(unlockedLbl);

  const grid = document.createElement('div');
  grid.className = 'unlocked-grid';
  grid.id = 'unlockedGrid';
  unlockedSection.appendChild(grid);
  box.appendChild(unlockedSection);

  function renderUnlocked() {
    grid.innerHTML = '';
    const redeemed = [...new Set(unlockedCodes)].filter(c => SECRET_CODES[c]);
    if (redeemed.length === 0) {
      const em = document.createElement('span');
      em.className = 'empty-unlocked';
      em.textContent = 'No secret items yet. Enter a code!';
      grid.appendChild(em);
    } else {
      redeemed.forEach(c => {
        const entry = SECRET_CODES[c];
        if (!entry) return;
        const tag = document.createElement('div');
        tag.className = 'unlocked-tag';
        const dot = document.createElement('span');
        dot.className = 'dot-secret';
        dot.style.background = entry.rarity === 'legendary' ? '#fbbf24' : entry.rarity === 'epic' ? '#a855f7' : '#60a5fa';
        tag.appendChild(dot);
        tag.appendChild(document.createTextNode(entry.label));
        grid.appendChild(tag);
      });
    }
  }
  renderUnlocked();

  modal.appendChild(box);
  document.body.appendChild(modal);
}

// ── INIT ──
level = buildLevel(1);
resetPlayer();
updateHUD();
draw();

showOverlay('🔥 OBBY RUSH V2', 'Jump over lava pits and reach the flag!', '🎨 CUSTOMIZE & PLAY', showCustomScreen);
</script>
